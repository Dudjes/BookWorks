generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Customer {
  userID     Int      @id @default(autoincrement())
  username   String
  password   String
  email      String   @unique
  role       String
  created_at DateTime @default(now())
  updated_at DateTime?
}
